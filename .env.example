# AssetFrame engine (assetframe-script) — copy to .env and fill in. NEVER commit .env.
# These are SHARED with the assetframe-infra (website) repo: same R2 bucket, same Neon DB.
# The engine WRITES (R2 files + Neon rows); the website READS.

# Cloudflare R2 — private report-file storage (publish.py uploads here)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=assetframe-pro

# Neon Postgres — sync-db.mjs writes editions + track record (both branches).
# Schema/migrations are owned by the assetframe-infra repo; the engine only INSERTs.
DATABASE_URL=
DATABASE_URL_DEV=

# Market-data provider API KEYS (secrets). Yahoo is the keyless default; set a provider in
# config/engine.json (ADVISOR_DATA_PROVIDER) + the matching key here to cut over. Any uncovered
# symbol (futures =F, indices ^) or failed fetch falls back to Yahoo, so a key never takes the
# engine down.  twelvedata — US equities/ETFs, forex incl. XAU/USD spot gold, crypto.  eodhd —
# global equities/forex (LSE 15-min delayed).
TWELVEDATA_API_KEY=
EODHD_API_KEY=

# Anthropic API — autonomous brief authoring (brief_writer.py + critic.py).
ANTHROPIC_API_KEY=

# Box control server (scripts/coordination/control_server.py, run by deploy/assetframe-control[-dev].
# service behind the Cloudflare Tunnel + Access). REQUIRED for that service to start — without
# CF_TEAM + CONTROL_AUD + CONTROL_TOKEN serve() fails closed (returns 1) and systemd crash-loops.
# (The poller/daily run do NOT need these — only the additive control service.) Set
# ASSETFRAME_CONTROL_INSECURE=1 for LOCAL DEV ONLY (skips the Access-JWT check).
ASSETFRAME_CONTROL_PORT=8787          # 8788 in the dev checkout
ASSETFRAME_CF_TEAM=                   # Zero Trust team name (e.g. wat044) -> issuer https://<team>.cloudflareaccess.com
ASSETFRAME_CONTROL_AUD=               # this env's Cloudflare Access application AUD
ASSETFRAME_CONTROL_TOKEN=             # random secret; the POST /control write factor (also a Vercel env var)

# NOTE: non-secret RUNTIME SETTINGS now live in config/engine.json (a single settings file):
#   ADVISOR_DATA_PROVIDER, TWELVEDATA_RATE_PER_MIN, ASSETFRAME_BRIEF_MODEL, ASSETFRAME_AUTHOR_BRIEFS,
#   ASSETFRAME_RETENTION_DAYS, ASSETFRAME_RUN_TIMEOUT. The dashboard "set config" command edits that
#   file. Any of these set in the real environment (or here) still WINS over engine.json. .env is for
#   SECRETS only (R2_*, DATABASE_URL, *_API_KEY, UPSTASH_*).
