# AssetFrame engine (assetframe-script) — copy to .env and fill in. NEVER commit .env.
# These are SHARED with the assetframe-infra (website) repo: same R2 bucket, same Neon DB.
# The engine WRITES (R2 files + Neon rows); the website READS.

# Cloudflare R2 — private report-file storage (publish.py uploads here)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=assetframe-pro

# Neon Postgres — sync-db.mjs writes editions + track record (both branches).
# Schema/migrations are owned by the assetframe-infra repo; the engine only INSERTs.
DATABASE_URL=
DATABASE_URL_DEV=

# Market data provider — Yahoo is the keyless default. Set ADVISOR_DATA_PROVIDER to a licensed
# feed + its key to cut over; any uncovered symbol (futures =F, indices ^) or failed fetch
# falls back to Yahoo automatically, so a key never takes the engine down.
#   twelvedata — US equities/ETFs, forex incl. XAU/USD spot gold, crypto. Basic free: 8 req/min,
#                800/day. Grow ($29): 55 req/min, no daily cap.
#   eodhd      — global equities/forex (LSE 15-min delayed); futures =F always via Yahoo
# TWELVEDATA_RATE_PER_MIN — your plan's per-minute credit limit (8 Basic, 55 Grow). The engine paces
#   TD calls to stay under it (and serializes assets only when <=30/min). Set 0 to disable pacing.
ADVISOR_DATA_PROVIDER=yahoo
TWELVEDATA_API_KEY=
TWELVEDATA_RATE_PER_MIN=8
EODHD_API_KEY=

# Anthropic API — Phase 2 (brief_writer.py + critic.py). Not needed for Phase 1.
ANTHROPIC_API_KEY=
