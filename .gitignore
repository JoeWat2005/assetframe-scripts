__pycache__/
*.pyc

# Engine working artifacts — regenerated every run (dirs auto-created on demand)
data/
reports/
content/
runs/
ledger/sim/

# The live ledger/outcome_ledger.csv is BOX-LOCAL working state: appended to in place
# every run, never committed back, and mirrored durably into Neon scored_results — so it
# stays UNTRACKED (score_report recreates the header if the file is absent). Keeping it out
# of git also stops `git pull --ff-only` deploys from ever conflicting on a dirty ledger.
# The rest below are derived products, rebuilt by calibrate.py / research_memory.py / ledger_db.py.
ledger/outcome_ledger.csv
ledger/calibration_map.json
ledger/research_memory.json
ledger/outcome_ledger.sqlite
ledger/backups/

# Secrets — never commit (the template IS committed)
.env
.env.*
!.env.example

# Node (the sync-db.mjs publish helper)
node_modules/

# OCI engine runner: the file lock serialising run_daily across the timer + poller.
.run.lock
