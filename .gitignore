__pycache__/
*.pyc

# Engine working artifacts — regenerated every run (dirs auto-created on demand)
data/
reports/
content/
runs/
ledger/sim/

# Derived ledger products — rebuilt by calibrate.py / research_memory.py / ledger_db.py.
# The source-of-truth ledger/outcome_ledger.csv stays tracked.
ledger/calibration_map.json
ledger/research_memory.json
ledger/outcome_ledger.sqlite
ledger/backups/

# Secrets — never commit (the template IS committed)
.env
.env.*
!.env.example

# Node (the sync-db.mjs publish helper)
node_modules/

# OCI engine runner: the file lock serialising run_daily across the timer + poller.
.run.lock
